# App
DATABASE_URL=file:./data/aicomic.db
UPLOAD_DIR=./uploads
HOST=0.0.0.0
PORT=3000

# Local GPU image generation (optional; see local_sd/README.md)
# Set to "local" to force GPU generation headlessly (Settings toggle does this too).
AICB_IMAGE_PROVIDER=
AICB_SD_URL=http://127.0.0.1:8500
AICB_SD_MODEL=

# AI providers (optional; can also be configured at runtime in Settings)
OPENAI_API_KEY=
OPENAI_BASE_URL=
GEMINI_API_KEY=
SEEDANCE_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
DASHSCOPE_API_KEY=
